import re
import logging

class ParserError(Exception):
    """Base exception for parser errors"""
    pass

class InvalidHTMLError(ParserError):
    """Raised when HTML is malformed or empty"""
    pass


class BaseParser:
    """
    Abstract base class for all HTML parsers.
    Provides common utilities for HTML parsing and text cleaning.
    Demonstrates: Inheritance, Abstraction, Code Reuse
    """
    
    def __init__(self):
        """Initialize parser with logging capability"""
        self.logger = logging.getLogger(self.__class__.__name__)
        self.logger.setLevel(logging.INFO)
    
    def extract(self, html):
        """
        Abstract method - must be implemented by subclasses.
        This demonstrates polymorphism.
        
        Args:
            html (str): HTML content to parse
            
        Returns:
            list: Extracted content
            
        Raises:
            NotImplementedError: If subclass doesn't implement this method
        """
        raise NotImplementedError(
            f"{self.__class__.__name__} must implement extract() method"
        )
    
    def strip_html_tags(self, text):
        """
        Remove all HTML tags from text.
        Uses regex to match any content between < and >
        
        Args:
            text (str): Text containing HTML tags
            
        Returns:
            str: Clean text without HTML tags
        """
        if not text:
            return ""
        
        # Remove HTML tags: matches <...> including attributes
        clean = re.sub(r'<[^>]+>', '', text)
        return clean.strip()
    
    def clean_text(self, text):
        """
        Clean and normalize extracted text.
        - Decodes HTML entities
        - Normalizes whitespace
        - Removes extra spaces
        
        Args:
            text (str): Raw extracted text
            
        Returns:
            str: Cleaned and normalized text
        """
        if not text:
            return ""
        
        # Decode common HTML entities
        text = text.replace('&nbsp;', ' ')
        text = text.replace('&amp;', '&')
        text = text.replace('&lt;', '<')
        text = text.replace('&gt;', '>')
        text = text.replace('&quot;', '"')
        text = text.replace('&#39;', "'")
        
        # Normalize whitespace: replace multiple spaces/newlines with single space
        text = re.sub(r'\s+', ' ', text)
        
        return text.strip()
    
    def validate_html(self, html):
        """
        Validate HTML input before processing.
        
        Args:
            html (str): HTML to validate
            
        Raises:
            InvalidHTMLError: If HTML is None, empty, or too short
        """
        if html is None:
            raise InvalidHTMLError("HTML is None")
        
        if not isinstance(html, str):
            raise InvalidHTMLError(f"HTML must be string, got {type(html)}")
        
        if len(html.strip()) == 0:
            raise InvalidHTMLError("HTML is empty")
        
        if len(html) < 10:
            raise InvalidHTMLError("HTML is too short to be valid")


class HeadlineParser(BaseParser):
    """
    Parser for extracting headlines from HTML (Stage 1).
    Extracts content from heading tags (h1, h2, h3, etc.)
    
    Demonstrates: Inheritance, Polymorphism, Dynamic Pattern Building
    """
    
    def __init__(self, tags=None):
        """
        Initialize headline parser.
        
        Args:
            tags (list, optional): List of heading tags to extract.
                                   Defaults to ['h1', 'h2', 'h3']
        """
        super().__init__()
        self.tags = tags or ['h1', 'h2', 'h3']
        self.logger.info(f"Initialized HeadlineParser with tags: {self.tags}")
    
    def extract(self, html):
        """
        Extract headlines from specified heading tags.
        Uses backreference \\1 to match closing tag with opening tag.
        
        Args:
            html (str): HTML content
            
        Returns:
            list: List of cleaned headline strings
            
        Raises:
            InvalidHTMLError: If HTML is invalid
        """
        # Validate input
        self.validate_html(html)
        
        # Build dynamic regex pattern for specified tags
        # Example: if tags = ['h1', 'h2'], pattern becomes '<(h1|h2)[^>]*>(.*?)</\\1>'
        tags_pattern = '|'.join(self.tags)
        
        # Pattern explanation:
        # <(h1|h2|h3)  - Match opening tag, capture tag name in group 1
        # [^>]*>       - Match any attributes until >
        # (.*?)        - Capture content (non-greedy), group 2
        # </\\1>       - Match closing tag that matches opening tag (backreference)
        pattern = f'<({tags_pattern})[^>]*>(.*?)</\\1>'
        
        # Find all matches (returns list of tuples: (tag, content))
        matches = re.findall(pattern, html, re.IGNORECASE | re.DOTALL)
        
        self.logger.info(f"Found {len(matches)} headline matches")
        
        # Process and clean each match
        results = []
        for tag, content in matches:
            # Remove nested HTML tags
            cleaned = self.strip_html_tags(content)
            # Clean whitespace and entities
            cleaned = self.clean_text(cleaned)
            
            # Only add non-empty headlines
            if cleaned:
                results.append(cleaned)
        
        self.logger.info(f"Extracted {len(results)} valid headlines")
        return results


class ArticleParser(BaseParser):
    """
    Parser for extracting full article content (Stage 2).
    Extracts content from <article> tags or specified container elements.
    
    Demonstrates: Inheritance, Polymorphism
    """
    
    def __init__(self, container_tag='article'):
        """
        Initialize article parser.
        
        Args:
            container_tag (str): HTML tag that contains article content.
                                 Defaults to 'article'
        """
        super().__init__()
        self.container_tag = container_tag
        self.logger.info(f"Initialized ArticleParser with tag: {container_tag}")
    
    def extract(self, html):
        """
        Extract article content from container tags.
        
        Args:
            html (str): HTML content
            
        Returns:
            list: List of article content strings
            
        Raises:
            InvalidHTMLError: If HTML is invalid
        """
        # Validate input
        self.validate_html(html)
        
        # Pattern to match article container
        # re.DOTALL makes . match newlines too
        pattern = f'<{self.container_tag}[^>]*>(.*?)</{self.container_tag}>'
        
        matches = re.findall(pattern, html, re.IGNORECASE | re.DOTALL)
        
        self.logger.info(f"Found {len(matches)} article matches")
        
        # Clean each article
        results = []
        for content in matches:
            cleaned = self.strip_html_tags(content)
            cleaned = self.clean_text(cleaned)
            
            if cleaned:
                results.append(cleaned)
        
        return results


class MetadataParser(BaseParser):
    """
    Parser for extracting metadata from HTML (Stage 3).
    Extracts meta tags, title, and other metadata.
    
    Demonstrates: Inheritance, Polymorphism, Dictionary Return Type
    """
    
    def __init__(self):
        """Initialize metadata parser"""
        super().__init__()
        self.logger.info("Initialized MetadataParser")
    
    def extract(self, html):
        """
        Extract metadata from HTML meta tags and title.
        
        Args:
            html (str): HTML content
            
        Returns:
            dict: Dictionary of metadata key-value pairs
            
        Raises:
            InvalidHTMLError: If HTML is invalid
        """
        # Validate input
        self.validate_html(html)
        
        metadata = {}
        
        # Extract title
        title_match = re.search(r'<title[^>]*>(.*?)</title>', html, re.IGNORECASE | re.DOTALL)
        if title_match:
            metadata['title'] = self.clean_text(title_match.group(1))
        
        # Extract meta tags (name/content pairs)
        # Matches: <meta name="description" content="...">
        meta_pattern = r'<meta[^>]*name=["\']([^"\']*)["\'][^>]*content=["\']([^"\']*)["\']'
        meta_matches = re.findall(meta_pattern, html, re.IGNORECASE)
        
        for name, content in meta_matches:
            metadata[name] = self.clean_text(content)
        
        # Also try reversed order: <meta content="..." name="...">
        meta_pattern_reversed = r'<meta[^>]*content=["\']([^"\']*)["\'][^>]*name=["\']([^"\']*)["\']'
        meta_matches_reversed = re.findall(meta_pattern_reversed, html, re.IGNORECASE)
        
        for content, name in meta_matches_reversed:
            if name not in metadata:  # Don't overwrite existing
                metadata[name] = self.clean_text(content)
        
        self.logger.info(f"Extracted {len(metadata)} metadata items")
        return metadata


class LinkParser(BaseParser):
    """
    Parser for extracting links from HTML.
    Useful for discovering new URLs to crawl.
    
    Demonstrates: Inheritance, URL Handling
    """
    
    def __init__(self, base_url=None):
        """
        Initialize link parser.
        
        Args:
            base_url (str, optional): Base URL for resolving relative links
        """
        super().__init__()
        self.base_url = base_url
        self.logger.info(f"Initialized LinkParser with base_url: {base_url}")
    
    def extract(self, html):
        """
        Extract all links (href attributes) from HTML.
        
        Args:
            html (str): HTML content
            
        Returns:
            list: List of URLs found in href attributes
            
        Raises:
            InvalidHTMLError: If HTML is invalid
        """
        # Validate input
        self.validate_html(html)
        
        # Pattern to match href attributes
        # Matches: href="..." or href='...'
        pattern = r'href=["\']([^"\']*)["\']'
        
        matches = re.findall(pattern, html, re.IGNORECASE)
        
        # Filter out empty links and anchors
        links = []
        for link in matches:
            link = link.strip()
            
            # Skip empty, javascript:, mailto:, tel:, and anchor links
            if not link or link.startswith(('#', 'javascript:', 'mailto:', 'tel:')):
                continue
            
            links.append(link)
        
        self.logger.info(f"Extracted {len(links)} links")
        return links


