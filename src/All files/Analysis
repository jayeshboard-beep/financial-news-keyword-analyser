class SentimentScorer(BaseAnalyser):#Calculates sentiment score from keyword matches.
    """    
    1. Error check
    2. Go through mathces + add weighted score
    3. Incldue modifies
    4. Classify overall sentiment 
    """
    def __init__(self, article_category=None, category_metadata=None):
        super().__init__(article_category)
        self.sentiment_weights = {}#Get cat sentiment multi
        for cat_name, cat_data in category_metadata.items():
            if 'sentiment_score' in cat_data:
                self.sentiment_weights[cat_name] = cat_data['sentiment_score']
        self.modifier_effects = {}#get multis
        for cat_name, cat_data in category_metadata.items():
            if 'multiplier' in cat_data:
                self.modifier_effects[cat_name] = cat_data['multiplier']
    
    def analyse(self, matches):#use matched wrod from aho to get sentiment 
        """
Return dict with following:
    Overall score
    sentiment
    pos score
    neg score
    keywords that give that sentiment
        """

     
        positive_score = 0.0
        negative_score = 0.0
        keyword_details = []
        
        for match in matches:
            category = match['category']
            if category not in self.sentiment_weights:
                continue
            base_weight = self.sentiment_weights[category]
            modifier = self._check_for_modifier(match, matches)# Multi check
            final_weight = base_weight * modifier
            if final_weight > 0:#Total work out
                positive_score += final_weight
            else:
                negative_score += abs(final_weight)
            keyword_details.append({
                'keyword': match['keyword'],
                'base_weight': base_weight,
                'modifier': modifier if modifier != 1.0 else None,
                'final_weight': final_weight,
                'context': match['context']
            })
        
        overall = positive_score - negative_score
        
        if overall > 5:#gedt user friendly sentiment based on score
            sentiment = 'POSITIVE'
        elif overall < -5:
            sentiment = 'NEGATIVE'
        else:
            sentiment = 'NEUTRAL'


        
        return {
            'overall_score': round(overall, 2),
            'sentiment': sentiment,
            'positive_score': round(positive_score, 2),
            'negative_score': round(negative_score, 2),
            'breakdown': keyword_details
        }
    
    def _check_for_modifier(self, current_match, all_matches):#use the 20 character away rule
  
        current_position = current_match['position']
        for match in all_matches:# Check each match
            category = match['category']
            if category not in self.modifier_effects:
                continue
            modifier_position = match['position']
            if modifier_position >= current_position:# multi before word
                continue
            distance = current_position - modifier_position
            if distance <= 20:#20 char check
                return self.modifier_effects[category]
        # No found
        return 1.0
    
    
    def _generate_neutral_output(self):#error protection
        return {
            'overall_score': 0.0,
            'sentiment': 'NEUTRAL',
            'positive_score': 0.0,
            'negative_score': 0.0,
            'breakdown': []
        }

class RiskTagger(BaseAnalyser):#Find specific risk events from keywords
    """
    Algo logic
    1. Error cehck
    2. Identify and group matches risk cat
    3. calc severity based on frequency
    4. calc  risk score
    5. Apply category multis
    """
    
    def __init__(self, article_category=None, category_metadata=None):
        super().__init__(article_category)
        
        # Extract risk scores
        self.risk_scores = {}
        for cat_name, cat_data in category_metadata.items():
            if 'risk_score' in cat_data:
                self.risk_scores[cat_name] = cat_data['risk_score']
        
        self.risk_categories = {
            'risk_financial': 'Financial Risk',
            'risk_legal': 'Legal Risk',
            'risk_quality': 'Quality/Operations Risk',
            'risk_market': 'Market Risk'
        }
        
        # severity thresholds based on keyword count
        self.severity_thresholds = {
            'HIGH': 5,      
            'MODERATE': 3,  
            'LOW': 1        
        }
        
    
    
    def analyse(self, matches):
        """
        analyse risk from keyword matches.
        
        Will output dict like below
             Detected risk:Risk detected from one keyword
            overall risk score:Summation of overall risk
             Primary risk:Most common risk found
             risk count:AMount of ties its come out
   
        """
        
        # Error handle
        if not matches:
            return self._generate_zero_risk_output()
        

        detected_risks = {}
        
        # Scan throug heach matcg
        for match in matches:
            category = match['category']
            if category not in self.risk_categories:# ignore non risk catergories
                continue
            risk_name = self.risk_categories[category]
            if risk_name not in detected_risks:#init risk catergory if first time seeing it
                detected_risks[risk_name] = {
                    'count': 0,
                    'keywords': [],
                    'evidence': [],
                    'category': category
                }
            detected_risks[risk_name]['count'] += 1
            detected_risks[risk_name]['keywords'].append(match['keyword'])
            detected_risks[risk_name]['evidence'].append(match['context'])
        
        # Error if no risk found
        if not detected_risks:
            return self._generate_zero_risk_output()
        for risk_name, risk_data in detected_risks.items():#Severity worked out
            count = risk_data['count']
            
            # Determine severity based on frequency
            if count >= self.severity_thresholds['HIGH']:
                severity = 'HIGH'
            elif count >= self.severity_thresholds['MODERATE']:
                severity = 'MODERATE'
            else:
                severity = 'LOW'
            
            risk_data['severity'] = severity
            risk_data['evidence'] = risk_data['evidence'][:3]
        
 
        overall_score = self._calculate_overall_risk(detected_risks)#apply multis to voverall risk score
        multiplier = self.get_category_multiplier()
        overall_score = overall_score * multiplier
        

        primary_risk = self._find_primary_risk(detected_risks)        # identify primary risk (highest severity)
        total_count = sum(data['count'] for data in detected_risks.values())        # Count total risk keywords
 
        return {
            'detected_risks': detected_risks,
            'overall_risk_score': round(overall_score, 2),
            'primary_risk': primary_risk,
            'risk_count': total_count,
            'category_multiplier': multiplier
        }
    
    
    def _calculate_overall_risk(self, detected_risks):
        """
        Calculate overall risk score from detected risks.
        Via severity and risk tagging
        """
 

        # Severity weights
        severity_weights = {
            'HIGH': 10,
            'MODERATE': 5,
            'LOW': 2
        }
        
        total_score = 0
        
 
        for risk_name, risk_data in detected_risks.items():#work out weight score
            severity = risk_data['severity']
            count = risk_data['count']
            weight = severity_weights[severity]
            risk_score = weight * count
            total_score += risk_score
        
        # create a standard for the score
        normalized_score = min(total_score * 2, 100) 
        return normalized_score
    
    
    def _find_primary_risk(self, detected_risks):
        """
        Find the primary (most severe) risk category to feedback to user
        """
        # Severity order for comparison
        severity_order = {'HIGH': 3, 'MODERATE': 2, 'LOW': 1}
        primary_risk = None
        highest_severity_value = 0
        highest_count = 0
        for risk_name, risk_data in detected_risks.items():
            severity = risk_data['severity']
            count = risk_data['count']
            severity_value = severity_order[severity]
            
            #Compare with current primary
            if severity_value > highest_severity_value:
                primary_risk = risk_name
                highest_severity_value = severity_value
                highest_count = count
            elif severity_value == highest_severity_value and count > highest_count:
                primary_risk = risk_name
                highest_count = count
        
        return primary_risk
    
    
    def _generate_zero_risk_output(self):
        return {
            'detected_risks': {},
            'overall_risk_score': 0.0,
            'primary_risk': None,
            'risk_count': 0,
            'category_multiplier': self.get_category_multiplier()
        }

class EventTrendsDatabase:
    """
    Stores historical event analysis results for trend prediction.
    """
    
    def __init__(self, csv_filepath="event_trends.csv"):
        self.csv_path = csv_filepath
        
        # Columns
        self.fieldnames = [
            'timestamp',
            'product', 
            'sector',
            'event_type',
            'sentiment_score',
            'risk_score',
            'volatility_score',
            'confidence_level',
            'trend_direction'
        ]
        
        # Create CSV if doesn't exist
        self._initialize_csv()
    
    
    def _initialize_csv(self):
        """Create CSV file with headers if it doesn't exist."""
        if os.path.exists(self.csv_path):
            return
        # Create new file with headers
        try:
            with open(self.csv_path, 'w', newline='') as f:
                writer = csv.DictWriter(f, fieldnames=self.fieldnames)
                writer.writeheader()
        except IOError as e:
            print(f"Error creating CSV file: {e}")
    
    
    def _validate_row(self, row_dict):
        """
        Check all headers have what is required from them
        """
        # Check required fields
        required = ['timestamp', 'sector', 'event_type']
        for field in required:
            if field not in row_dict:
                return False
            if not row_dict[field]:
                return False
        # error check with data types
        numeric_fields = ['sentiment_score', 'risk_score', 'volatility_score']
        for field in numeric_fields:
            if field in row_dict and row_dict[field]:
                try:
                    float(row_dict[field])
                except ValueError:
                    return False
        return True
    
    
    def save_event(self, event_data):
        """
        Save a new event analysis to the CSV file.
        """ 
        if not self._validate_row(event_data):# Validate data
            print("Error: Invalid event data")
            return False
        if 'timestamp' not in event_data or not event_data['timestamp']:# Add timestamp 
            event_data['timestamp'] = datetime.now().isoformat()
        try:#CSV append
            with open(self.csv_path, 'a', newline='') as f:
                writer = csv.DictWriter(f, fieldnames=self.fieldnames)
                writer.writerow(event_data)
            return True
        except IOError as e:
            print(f"Error writing to CSV: {e}")
            return False

    def query_events(self, sector, event_type):
        """
        Find all past events matching the sector and event type.
        Returns list of matching event dictionaries.
        """
        matches = []
        
        # Oopen and read CSV
        try:
            with open(self.csv_path, 'r', newline='') as f:
                reader = csv.DictReader(f)
                for row in reader:#Loop through rows
                    if not self._validate_row(row):
                        continue
                    if row['sector'] == sector and row['event_type'] == event_type:
                        matches.append(row)
            return matches
            
        except FileNotFoundError:
            return []
    
    
    def predict_trend(self, sector, event_type):#use past trend for indication of future
        events = self.query_events(sector, event_type)
        if len(events) < 3:# skew protection
            return {
                'prediction': 'INSUFFICIENT_DATA',
                'confidence': 0.0,
                'sample_size': len(events)
            }
        #trned driection calcultio 
        upward = 0
        downward = 0
        neutral = 0
        for event in events:
            direction = event['trend_direction']
            
            if direction == 'UPWARD':
                upward += 1
            elif direction == 'DOWNWARD':
                downward += 1
            else:
                neutral += 1
        
        # Find strongest 
        total = len(events)
        if upward >= downward and upward >= neutral:
            winner = 'UPWARD'
            winner_count = upward
        elif downward >= upward and downward >= neutral:
            winner = 'DOWNWARD'
            winner_count = downward
        else:
            winner = 'NEUTRAL'
            winner_count = neutral#Evaluate for winner 
        confidence = (winner_count / total) * 100
        return {
            'prediction': winner,
            'confidence': round(confidence, 1),
            'sample_size': total
        }
    
    def calculate_trend_direction(self, sentiment_score, volatility_score):
        """
        Calculate trend direction from sentiment and volatility scores.
        """
        if volatility_score > 60:# High vola = unreliable prediction
            return 'NEUTRAL'
        if sentiment_score > 5: # Low vola means we can trust sentiment
            return 'UPWARD'
        elif sentiment_score < -5:
            return 'DOWNWARD'
        else:
            return 'NEUTRAL'


class HeadlineFrequencyTracker(BaseAnalyser):
    """
    Tracks frequency of headliens being mentions
    """
    
    def analyse(self, headlines, product_name):
        """
        analyse headline frequency for a product.

        returns Dictionary with frequency analysis results
        """

            
        mention_count = 0#headline count
        total_headlines = len(headlines)
        
        # search for the product name 
        for headline in headlines:
            if product_name.lower() in headline.lower():
                mention_count += 1
        
        # % calculation 
        if total_headlines > 0:
            percentage = (mention_count / total_headlines) * 100
        else:
            percentage = 0
        attention_level = self._get_attention_level(percentage)
        return {
            'mention_count': mention_count,
            'total_headlines': total_headlines,
            'percentage': round(percentage, 1),
            'attention_level': attention_level
        }
    def _get_attention_level(self, percentage):#turn user friendly
        if percentage >= 60:
            return 'HIGH'
        elif percentage >= 30:
            return 'MODERATE'
        else:
            return 'LOW'
class ContradictionDetector(BaseAnalyser):
#Work out contradictionusing headlines     
    def __init__(self, aho_corasick, category_metadata):#init everything
        super().__init__()
        self.aho_corasick = aho_corasick
        self.category_metadata = category_metadata 
    
    def analyse(self, headlines):
        if not headlines or len(headlines) < 2:
            return None
        
        # Step 1:Headline list
        headline_sentiments = []
        for headline in headlines:
            sentiment = self._analyse_headline_sentiment(headline)
            headline_sentiments.append({
                'text': headline,
                'sentiment': sentiment
            })
        
        # Step 2:Give eachs netiment word a score
        positive_count = 0
        negative_count = 0
        neutral_count = 0
        
        for item in headline_sentiments:
            if item['sentiment'] == 'POSITIVE':
                positive_count += 1
            elif item['sentiment'] == 'NEGATIVE':
                negative_count += 1
            else:
                neutral_count += 1
        
        # Step 3: Contradiction checks
        contradiction_detected = False
        if positive_count > 0 and negative_count > 0:
            contradiction_detected = True
        conflicting_pairs = []
        if contradiction_detected:
            conflicting_pairs = self._find_conflicting_pairs(headline_sentiments)
        score = self._calculate_contradiction_score(positive_count, negative_count, neutral_count)
        
        return {
            'contradiction_detected': contradiction_detected,
            'score': score,
            'positive_count': positive_count,
            'negative_count': negative_count,
            'neutral_count': neutral_count,
            'conflicting_pairs': conflicting_pairs
        }
    
    def _analyse_headline_sentiment(self, headline):#Sentiment of a single headline usign Aho-Corasick
        matches = self.aho_corasick.search(headline)
        if not matches:
            return 'NEUTRAL'
        total_score = 0#sent score 
        for match in matches:
            category = match['category']
            if category in self.category_metadata:# Look up sentiment score directly via metadata 
                cat_data = self.category_metadata[category]
                weight = cat_data.get('sentiment_score', 0)
                total_score = total_score + weight
        if total_score > 0:
            return 'POSITIVE'
        elif total_score < 0:
            return 'NEGATIVE'
        else:
            return 'NEUTRAL'
    
    def _find_conflicting_pairs(self, headline_sentiments):

        conflicting_pairs = []
        positive_headlines = [h for h in headline_sentiments if h['sentiment'] == 'POSITIVE']
        negative_headlines = [h for h in headline_sentiments if h['sentiment'] == 'NEGATIVE']
        
        # Pair p and n
        for i in range(min(3, len(positive_headlines), len(negative_headlines))):
            pair = {
                'positive': positive_headlines[i]['text'],
                'negative': negative_headlines[i]['text']
            }
            conflicting_pairs.append(pair)
        
        return conflicting_pairs
    
    def _calculate_contradiction_score(self, positive_count, negative_count, neutral_count):

        total = positive_count + negative_count + neutral_count        
        if total == 0:
            return 0
        if positive_count == total or negative_count == total or neutral_count == total:#no contradiction
            return 0
        smaller = min(positive_count, negative_count)# Calculate balance (closer to 50/50 = higher score)
        larger = max(positive_count, negative_count)
        if larger == 0:
            return 0
        balance_ratio = smaller / larger
        score = balance_ratio * 10
        return round(score)

class TrendVolatilityanalyser(BaseAnalyser):
    """
   Parts
    1. sentiment balance volatility (0-35)
    2. contradiction signals (0-25 points)
    3. frequency spike indicators (0-20 points)
    4. emotional language intensity (0-20 points)
    5. Combine scores + determine confidence level
    """
    
    def __init__(self, article_category=None, category_metadata=None):
        super().__init__(article_category)
        self.volatility_scores = {}#get volatility
        for cat_name, cat_data in category_metadata.items():
            if 'volatility_score' in cat_data:
                self.volatility_scores[cat_name] = cat_data['volatility_score']
        self.confidence_thresholds = {#use vol to measure cofnidence 
            'HIGH': 30,      # 0-30 = confident trend prediction
            'MODERATE': 60,  # 31-60 = moderate confidence
            'LOW': 100       # 61-100 = low confidence 
        }
    


    
    def analyse(self, sentiment_result, frequency_result, contradiction_result, keyword_matches):
        """
        Outputs voltality scofre
                    Confidence
                    Componets(where scores come from )
                    Interpretation on why this comes from
        """
        
        # Final volatility 
        balance_component = self._calculate_balance_volatility(sentiment_result)
        contradiction_component = self._calculate_contradiction_volatility(contradiction_result)
        frequency_component = self._calculate_frequency_volatility(frequency_result)
        emotion_component = self._calculate_emotion_volatility(keyword_matches)
        total_volatility = balance_component + contradiction_component + frequency_component + emotion_component# combine     
        if total_volatility > 100:
            total_volatility = 100
        

        
        confidence = self._determine_confidence(total_volatility)

        

        interpretation = self._generate_interpretation(#intertation
            total_volatility, 
            balance_component, 
            contradiction_component, 
            frequency_component, 
            emotion_component
        )
        return {
            'volatility_score': round(total_volatility, 2),
            'confidence_level': confidence,
            'components': {
                'sentiment_balance': round(balance_component, 2),
                'contradictions': round(contradiction_component, 2),
                'frequency_spike': round(frequency_component, 2),
                'emotional_intensity': round(emotion_component, 2)
            },
            'interpretation': interpretation
        }
    
    
    def _calculate_balance_volatility(self, sentiment_result):#Calc voltatlity(step 1)

        positive_score = sentiment_result.get('positive_score', 0.0)
        negative_score = sentiment_result.get('negative_score', 0.0)
        total_score = positive_score + negative_score# Calculate total sentiment 
        # error handle for if both P and N are 0
        if total_score == 0:
            return 0.0
        score_difference = abs(positive_score - negative_score)# Calculate diff of scores 
        balance_ratio = score_difference / total_score
        balance_volatility = 1.0 - balance_ratio# invert to balance ratio--> volatility
        component_score = balance_volatility * 35
        return component_score

    def _calculate_contradiction_volatility(self, contradiction_result):#step 2 calc volatility
    
        contradiction_detected = contradiction_result.get('contradiction_detected', False)#Contradiction cehck
        if contradiction_detected:#Volatlity check
            return 25.0
        else:
            return 0.0


        # Error check
        if contradiction_result is None:
            return 0.0
    
    def _calculate_frequency_volatility(self, frequency_result):#step 3(frequency spikes)
        attention_level = frequency_result.get('attention_level', 'LOW')
        if attention_level == 'HIGH':
            return 20.0
        elif attention_level == 'MODERATE':
            return 10.0
        else:
            return 0.0

        # error protect
        if frequency_result is None:
            return 0.0
    
    def _calculate_emotion_volatility(self, keyword_matches):#Calc volatility from emotional language(step 4)
        emotion_count = 0
        
        for match in keyword_matches:
            category = match['category']
            if 'strong' in category: # check for strong sentiment keywords
                emotion_count += 1
            elif category == 'volatility_emotional': # check for volatility emotional keywords
                emotion_count += 1
            elif category == 'modifier_intensifier':# check for intensifier modifiers
                emotion_count += 1 
        emotion_score = emotion_count * 2# Each emotional keyword adds 2 points
        if emotion_score > 20:
            emotion_score = 20
        return float(emotion_score)
    
    
    def _determine_confidence(self, volatility_score):#Step 5 work out confidence level in trends
        if volatility_score <= self.confidence_thresholds['HIGH']:
            return 'HIGH'
        elif volatility_score <= self.confidence_thresholds['MODERATE']:
            return 'MODERATE'
        else:
            return 'LOW'
    
    
    def _generate_interpretation(self, total_volatility, balance, contradiction, frequency, emotion):

        
        # Start with initial 
        if total_volatility <= 30:
            base = "Low volatility detected - market sentiment is stable and clear."
        elif total_volatility <= 60:
            base = "Moderate volatility detected - some market uncertainty present."
        else:
            base = "High volatility detected - significant market uncertainty and instability."
        contributors = []# Add details 
        
        if balance > 20:
            contributors.append("conflicting sentiment scores")  
        if contradiction > 0:
            contributors.append("contradictory headlines")        
        if frequency > 0:
            contributors.append("sudden attention spike")        
        if emotion > 10:
            contributors.append("strong emotional language")
        #Final intepretation
        if contributors:
            details = ", ".join(contributors)
            interpretation = f"{base} Primary factors: {details}."
        else:
            interpretation = base
        return interpretation

class ROICalculator:
    def __init__(self, category_metadata=None):
        self.category_metadata = category_metadata
        
        # 7 levels for net score
        self.thresholds = {
            'STRONG_POSITIVE': 30,
            'MODERATE_POSITIVE': 15,
            'WEAK_POSITIVE': 5,
            'NEUTRAL': -5,
            'WEAK_NEGATIVE': -15,
            'MODERATE_NEGATIVE': -30
            #below -30 is STRONG_NEGATIVE
        }
    
    
    def calculate(self, analyser_results):
        """
        Fianl bringing everything together
        
        Input: dict with 
               keys sentiment, 
               risk, 
               volatility, 
               frequency, 
               contradictions,
               trend_prediction
               
        Output: dict with indicator, scores, both recommendation formats
        """
        validated = self._validate_inputs(analyser_results)#Validate inputs
        
        opportunity = self._calculate_opportunity(validated)
        risk = self._calculate_risk(validated)
        confidence = self._calculate_confidence(validated)
        
        
        net_score = (opportunity - risk) * (confidence / 100)# multiplicative so low confidence
        indicator = self._get_indicator(net_score)#user friendly
        
        user_recommendation = self._build_user_recommendation(
            indicator, validated, net_score
        )
        technical_recommendation = self._build_technical_recommendation(
            indicator, opportunity, risk, confidence, validated
        )
        return {
            'indicator': indicator,
            'net_score': round(net_score, 2),
            'opportunity_score': round(opportunity, 2),
            'risk_score': round(risk, 2),
            'confidence_score': round(confidence, 2),
            'user_recommendation': user_recommendation,
            'technical_recommendation': technical_recommendation
        }
    
    
    def _validate_inputs(self, analyser_results):
        #if returns 0 we can change into format that dont crash program
        validated = {}

        if analyser_results.get('sentiment') is not None:#Validate Sentiments
            validated['sentiment'] = analyser_results['sentiment']
        else:
            validated['sentiment'] = {
                'overall_score': 0.0,
                'sentiment': 'NEUTRAL',
                'positive_score': 0.0,
                'negative_score': 0.0
            }

        
        if analyser_results.get('risk') is not None:#Risk validation
            validated['risk'] = analyser_results['risk']
        else:
            validated['risk'] = {
                'overall_risk_score': 0.0,
                'primary_risk': None,
                'risk_count': 0,
                'detected_risks': {}
            }
        
        if analyser_results.get('volatility') is not None:# Volatility volatlity
            validated['volatility'] = analyser_results['volatility']
        else:
            validated['volatility'] = {
                'volatility_score': 50.0,
                'confidence_level': 'LOW'
            }
        if analyser_results.get('frequency') is not None:#Frequency validatiob
            validated['frequency'] = analyser_results['frequency']
        else:
            validated['frequency'] = {
                'attention_level': 'LOW',
                'percentage': 0.0
            }

        
        # Contradiction validation
        if analyser_results.get('contradictions') is not None:
            validated['contradictions'] = analyser_results['contradictions']
        else:
            validated['contradictions'] = {
                'contradiction_detected': False,
                'score': 0
            }
        
        # valid Trend prediction
        if analyser_results.get('trend_prediction') is not None:
            validated['trend_prediction'] = analyser_results['trend_prediction']
        else:
            validated['trend_prediction'] = {
                'prediction': 'INSUFFICIENT_DATA',
                'confidence': 0.0,
                'sample_size': 0
            }
        return validated
    
    def _calculate_opportunity(self, validated):
        """
        calculate opportunity score via sentiment and frequency.

        high frequency + p sentiment = Opportunity
        High frequency + N sentiment = No Opportunity + Increase risk
        """
        sentiment_data = validated['sentiment']
        frequency_data = validated['frequency']
        
        base_opportunity = sentiment_data.get('positive_score', 0.0)
        attention = frequency_data.get('attention_level', 'LOW')#Frequency adjust
        sentiment_direction = sentiment_data.get('sentiment', 'NEUTRAL')
        frequency_boost = 0.0
        if attention == 'HIGH' and sentiment_direction == 'POSITIVE':#= Opportunity
            frequency_boost = 10.0
        elif attention == 'MODERATE' and sentiment_direction == 'POSITIVE':
            frequency_boost = 5.0

        
        # If sentiment is negative we dont add to opportunity
       
        
        trend_data = validated['trend_prediction']#Use historical data 
        trend_boost = 0.0
        if trend_data['prediction'] == 'UPWARD':
            trend_boost = 5.0



        
        total_opportunity = base_opportunity + frequency_boost + trend_boost
        return total_opportunity
    


    
    def _calculate_risk(self, validated):
        """
        calc risk score using risk tagger and frequency interaction.
        Factor in High frequency + N sentiment + More risk from above function
        """
        risk_data = validated['risk']
        frequency_data = validated['frequency']
        sentiment_data = validated['sentiment']

        base_risk = risk_data.get('overall_risk_score', 0.0)
        attention = frequency_data.get('attention_level', 'LOW')#=Higher risk
        sentiment_direction = sentiment_data.get('sentiment', 'NEUTRAL')
        
        frequency_penalty = 0.0
        if attention == 'HIGH' and sentiment_direction == 'NEGATIVE':
            frequency_penalty = 10.0
        elif attention == 'MODERATE' and sentiment_direction == 'NEGATIVE':
            frequency_penalty = 5.0
        
        trend_data = validated['trend_prediction']#Use historical stuff
        trend_penalty = 0.0
        if trend_data['prediction'] == 'DOWNWARD':
            trend_penalty = 5.0
        
        total_risk = base_risk + frequency_penalty + trend_penalty
        return total_risk
    
    
    def _calculate_confidence(self, validated):
        """
    COnficne based on valotility
        starts at 100 and gets reduced by penalties.
        """
        confidence = 100.0#Base set
        
        # volatility penalty is the biggest factor (1:1)
        volatility_data = validated['volatility']
        volatility_penalty = volatility_data.get('volatility_score', 50.0)
        confidence = confidence - volatility_penalty
        
        # Sample size penalty :historic data = small   then less reliable
        trend_data = validated['trend_prediction']
        sample_size = trend_data.get('sample_size', 0)
        if sample_size < 5:
            confidence = confidence - 20.0
 
        contradiction_data = validated['contradictions']# contradiction penalty
        if contradiction_data.get('contradiction_detected', False):
            confidence = confidence - 15.0

        if confidence < 0:
            confidence = 0.0
        if confidence > 100:
            confidence = 100.0        
        return confidence
    

    
    def _get_indicator(self, net_score):
        """
        Convert the net score number into one of 7 categories.
        """
        if net_score > self.thresholds['STRONG_POSITIVE']:
            return 'STRONG_POSITIVE'
        elif net_score > self.thresholds['MODERATE_POSITIVE']:
            return 'MODERATE_POSITIVE'
        elif net_score > self.thresholds['WEAK_POSITIVE']:
            return 'WEAK_POSITIVE'
        elif net_score >= self.thresholds['NEUTRAL']:
            return 'NEUTRAL'
        elif net_score > self.thresholds['WEAK_NEGATIVE']:
            return 'WEAK_NEGATIVE'
        elif net_score > self.thresholds['MODERATE_NEGATIVE']:
            return 'MODERATE_NEGATIVE'
        else:
            return 'STRONG_NEGATIVE'
    
    
