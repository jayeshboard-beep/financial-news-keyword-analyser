class ContradictionDetector(BaseAnalyser):
    """
    Detects contradictory sentiment signals across headlines.
    Contradictions indicate market uncertainty and increased risk.
    
    Method:
    1: Find out sentiment for each headline
    2:Count positive vs negative headlines
    3:Check for contraciction/contradicting pairs
    """
    
    def __init__(self, aho_corasick, category_metadata):
        super().__init__()
        self.aho_corasick = aho_corasick
        self.category_metadata = category_metadata 
    
    def analyse(self, headlines):

        if not headlines or len(headlines) < 2:#Error handling
            return None
        
        # Step 1
        headline_sentiments = []
        for headline in headlines:
            sentiment = self._analyse_headline_sentiment(headline)
            headline_sentiments.append({
                'text': headline,
                'sentiment': sentiment
            })
        
        # Step 2
        positive_count = 0
        negative_count = 0
        neutral_count = 0
        
        for item in headline_sentiments:
            if item['sentiment'] == 'POSITIVE':
                positive_count += 1
            elif item['sentiment'] == 'NEGATIVE':
                negative_count += 1
            else:
                neutral_count += 1
        
        # Step 3: Check for contradictions
        contradiction_detected = False
        if positive_count > 0 and negative_count > 0:
            contradiction_detected = True
        conflicting_pairs = []
        if contradiction_detected:
            conflicting_pairs = self._find_conflicting_pairs(headline_sentiments)
        
        # Calculate contradiction score (0-10 scale)
        score = self._calculate_contradiction_score(positive_count, negative_count, neutral_count)
        
        return {
            'contradiction_detected': contradiction_detected,
            'score': score,
            'positive_count': positive_count,
            'negative_count': negative_count,
            'neutral_count': neutral_count,
            'conflicting_pairs': conflicting_pairs
        }
    
    def _analyse_headline_sentiment(self, headline):
        #Determine sentiment of a single headline using Aho-Corasick.
        # BUG FIX 2: Uses match category directly instead of broken _get_keyword_weight

        matches = self.aho_corasick.search(headline)
        if not matches:
            return 'NEUTRAL'
        
        # Calculate sentiment score from matches
        total_score = 0
        for match in matches:
            category = match['category']
            # Look up sentiment score directly from category metadata
            if category in self.category_metadata:
                cat_data = self.category_metadata[category]
                weight = cat_data.get('sentiment_score', 0)
                total_score = total_score + weight
        
        # Determine sentiment based on total score
        if total_score > 0:
            return 'POSITIVE'
        elif total_score < 0:
            return 'NEGATIVE'
        else:
            return 'NEUTRAL'
    
    def _find_conflicting_pairs(self, headline_sentiments):

        #Find pairs of headlines with opposite sentiments.

        conflicting_pairs = []
        
        # Find positive headlines
        positive_headlines = [h for h in headline_sentiments if h['sentiment'] == 'POSITIVE']
        # Find negative headlines
        negative_headlines = [h for h in headline_sentiments if h['sentiment'] == 'NEGATIVE']
        
        # Pair them up (just take first few for simplicity)
        for i in range(min(3, len(positive_headlines), len(negative_headlines))):
            pair = {
                'positive': positive_headlines[i]['text'],
                'negative': negative_headlines[i]['text']
            }
            conflicting_pairs.append(pair)
        
        return conflicting_pairs
    
    def _calculate_contradiction_score(self, positive_count, negative_count, neutral_count):
        """
        Calculate contradiction score based on sentiment distribution.
        Higher score = more disagreement = higher uncertainty.

        """
        total = positive_count + negative_count + neutral_count
        
        if total == 0:
            return 0
        
        # If all same sentiment, no contradiction
        if positive_count == total or negative_count == total or neutral_count == total:
            return 0
        
        # Calculate balance (closer to 50/50 = higher score)
        smaller = min(positive_count, negative_count)
        larger = max(positive_count, negative_count)
        
        if larger == 0:
            return 0
        
        balance_ratio = smaller / larger

        score = balance_ratio * 10
        
        return round(score)


