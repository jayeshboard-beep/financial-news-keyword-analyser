# Make sure the method is called "calculate" and accepts a dict with keys:
#   sentiment, risk, volatility, frequency, contradictions, trend_prediction

class ROICalculator:
    """
    Combines all analyser outputs into final ROI recommendation.
    Uses multiplicative confidence so low confidence drastically 
    reduces the score even if opportunity looks good.
    
    Formula: net_score = (opportunity - risk) * (confidence / 100)
    
    7 level system from STRONG_POSITIVE to STRONG_NEGATIVE.
    Also generates both user friendly and technical recommendations.
    """
    
    def __init__(self, category_metadata=None):
        self.category_metadata = category_metadata
        
        # 7 level thresholds for categorising the net score
        # Wider neutral zone (-5 to 5) catches genuinely balanced scenarios
        self.thresholds = {
            'STRONG_POSITIVE': 30,
            'MODERATE_POSITIVE': 15,
            'WEAK_POSITIVE': 5,
            'NEUTRAL': -5,
            'WEAK_NEGATIVE': -15,
            'MODERATE_NEGATIVE': -30
            # anything below -30 is STRONG_NEGATIVE
        }
    
    
    def calculate(self, analyser_results):
        """
        Main calculation method. Takes all analyser outputs and
        produces the final recommendation.
        
        Input: dict with keys sentiment, risk, volatility, 
               frequency, contradictions, trend_prediction
        Output: dict with indicator, scores, both recommendation formats
        """
        
        # Validate inputs first - some analysers might return None
        # if there wasnt enough data (Problem 13 fix)
        validated = self._validate_inputs(analyser_results)
        
        # Calculate the three main components
        opportunity = self._calculate_opportunity(validated)
        risk = self._calculate_risk(validated)
        confidence = self._calculate_confidence(validated)
        
        # The big formula - multiplicative so low confidence
        # drastically reduces the final score
        net_score = (opportunity - risk) * (confidence / 100)
        
        # Turn the number into a category the user can understand
        indicator = self._get_indicator(net_score)
        
        # Generate both recommendation formats
        user_recommendation = self._build_user_recommendation(
            indicator, validated, net_score
        )
        technical_recommendation = self._build_technical_recommendation(
            indicator, opportunity, risk, confidence, validated
        )
        
        return {
            'indicator': indicator,
            'net_score': round(net_score, 2),
            'opportunity_score': round(opportunity, 2),
            'risk_score': round(risk, 2),
            'confidence_score': round(confidence, 2),
            'user_recommendation': user_recommendation,
            'technical_recommendation': technical_recommendation
        }
    
    
    def _validate_inputs(self, analyser_results):
        """
        Check each analyser actually returned data.
        If any returned None we replace with safe defaults
        so the calculation doesnt crash. (Problem 13 fix)
        """
        validated = {}
        
        # Sentiment defaults
        if analyser_results.get('sentiment') is not None:
            validated['sentiment'] = analyser_results['sentiment']
        else:
            validated['sentiment'] = {
                'overall_score': 0.0,
                'sentiment': 'NEUTRAL',
                'positive_score': 0.0,
                'negative_score': 0.0
            }
        
        # Risk defaults
        if analyser_results.get('risk') is not None:
            validated['risk'] = analyser_results['risk']
        else:
            validated['risk'] = {
                'overall_risk_score': 0.0,
                'primary_risk': None,
                'risk_count': 0,
                'detected_risks': {}
            }
        
        # Volatility defaults
        if analyser_results.get('volatility') is not None:
            validated['volatility'] = analyser_results['volatility']
        else:
            validated['volatility'] = {
                'volatility_score': 50.0,
                'confidence_level': 'LOW'
            }
        
        # Frequency defaults
        if analyser_results.get('frequency') is not None:
            validated['frequency'] = analyser_results['frequency']
        else:
            validated['frequency'] = {
                'attention_level': 'LOW',
                'percentage': 0.0
            }
        
        # Contradiction defaults
        if analyser_results.get('contradictions') is not None:
            validated['contradictions'] = analyser_results['contradictions']
        else:
            validated['contradictions'] = {
                'contradiction_detected': False,
                'score': 0
            }
        
        # Trend prediction defaults
        if analyser_results.get('trend_prediction') is not None:
            validated['trend_prediction'] = analyser_results['trend_prediction']
        else:
            validated['trend_prediction'] = {
                'prediction': 'INSUFFICIENT_DATA',
                'confidence': 0.0,
                'sample_size': 0
            }
        
        return validated
    
    
    def _calculate_opportunity(self, validated):
        """
        Calculate opportunity score from sentiment and frequency.
        
        Key logic: high frequency only boosts opportunity when
        sentiment is positive. If sentiment is negative then
        high frequency actually adds to risk instead.
        """
        sentiment_data = validated['sentiment']
        frequency_data = validated['frequency']
        
        # Start with the positive sentiment score as base opportunity
        base_opportunity = sentiment_data.get('positive_score', 0.0)
        
        # Frequency adjustment - this is where the interaction happens
        attention = frequency_data.get('attention_level', 'LOW')
        sentiment_direction = sentiment_data.get('sentiment', 'NEUTRAL')
        
        frequency_boost = 0.0
        if attention == 'HIGH' and sentiment_direction == 'POSITIVE':
            # Lots of good news = growth potential
            frequency_boost = 10.0
        elif attention == 'MODERATE' and sentiment_direction == 'POSITIVE':
            frequency_boost = 5.0
        # If sentiment is negative we dont add to opportunity
        # the risk calculator handles that case instead
        
        # Historical trend can also boost opportunity
        trend_data = validated['trend_prediction']
        trend_boost = 0.0
        if trend_data['prediction'] == 'UPWARD':
            # Past events suggest positive outcome
            trend_boost = 5.0
        
        total_opportunity = base_opportunity + frequency_boost + trend_boost
        return total_opportunity
    
    
    def _calculate_risk(self, validated):
        """
        Calculate risk score from risk tagger and frequency interaction.
        High frequency + negative sentiment increases risk.
        """
        risk_data = validated['risk']
        frequency_data = validated['frequency']
        sentiment_data = validated['sentiment']
        
        # Start with the risk analysers overall score
        base_risk = risk_data.get('overall_risk_score', 0.0)
        
        # Frequency + negative sentiment interaction
        # Lots of bad news = danger signal
        attention = frequency_data.get('attention_level', 'LOW')
        sentiment_direction = sentiment_data.get('sentiment', 'NEUTRAL')
        
        frequency_penalty = 0.0
        if attention == 'HIGH' and sentiment_direction == 'NEGATIVE':
            frequency_penalty = 10.0
        elif attention == 'MODERATE' and sentiment_direction == 'NEGATIVE':
            frequency_penalty = 5.0
        
        # Historical trend can increase risk too
        trend_data = validated['trend_prediction']
        trend_penalty = 0.0
        if trend_data['prediction'] == 'DOWNWARD':
            trend_penalty = 5.0
        
        total_risk = base_risk + frequency_penalty + trend_penalty
        return total_risk
    
    
    def _calculate_confidence(self, validated):
        """
        Calculate how confident we are in our prediction.
        Volatility is the biggest factor - if market is unstable
        then even good looking opportunities cant be trusted.
        
        Starts at 100 and gets reduced by penalties.
        """
        # Start at maximum confidence
        confidence = 100.0
        
        # Volatility penalty is the dominant factor (1:1 ratio)
        volatility_data = validated['volatility']
        volatility_penalty = volatility_data.get('volatility_score', 50.0)
        confidence = confidence - volatility_penalty
        
        # Sample size penalty - if we dont have much historical data
        # then our trend prediction is less reliable
        trend_data = validated['trend_prediction']
        sample_size = trend_data.get('sample_size', 0)
        if sample_size < 5:
            confidence = confidence - 20.0
        
        # Contradiction penalty - if headlines disagree
        # then the market is confused and so are we
        contradiction_data = validated['contradictions']
        if contradiction_data.get('contradiction_detected', False):
            confidence = confidence - 15.0
        
        # Make sure confidence stays between 0 and 100
        if confidence < 0:
            confidence = 0.0
        if confidence > 100:
            confidence = 100.0
        
        return confidence
    
    
    def _get_indicator(self, net_score):
        """
        Convert the net score number into one of 7 categories.
        Goes from STRONG_POSITIVE down to STRONG_NEGATIVE.
        """
        if net_score > self.thresholds['STRONG_POSITIVE']:
            return 'STRONG_POSITIVE'
        elif net_score > self.thresholds['MODERATE_POSITIVE']:
            return 'MODERATE_POSITIVE'
        elif net_score > self.thresholds['WEAK_POSITIVE']:
            return 'WEAK_POSITIVE'
        elif net_score >= self.thresholds['NEUTRAL']:
            return 'NEUTRAL'
        elif net_score > self.thresholds['WEAK_NEGATIVE']:
            return 'WEAK_NEGATIVE'
        elif net_score > self.thresholds['MODERATE_NEGATIVE']:
            return 'MODERATE_NEGATIVE'
        else:
            return 'STRONG_NEGATIVE'
    
    
    def _build_user_recommendation(self, indicator, validated, net_score):
        """
        Build the user friendly recommendation in plain english.
        This is for users who just want a clear answer with reasoning.
        """
        risk_data = validated['risk']
        primary_risk = risk_data.get('primary_risk', None)
        sentiment_data = validated['sentiment']
        
        # Start with the main conclusion based on indicator
        if indicator == 'STRONG_POSITIVE':
            main_msg = "Strong investment opportunity detected."
        elif indicator == 'MODERATE_POSITIVE':
            main_msg = "Moderate investment opportunity detected."
        elif indicator == 'WEAK_POSITIVE':
            main_msg = "Slight positive signal but proceed with caution."
        elif indicator == 'NEUTRAL':
            main_msg = "No clear signal detected. Market is balanced or uncertain."
        elif indicator == 'WEAK_NEGATIVE':
            main_msg = "Slight negative signal. Consider waiting for better conditions."
        elif indicator == 'MODERATE_NEGATIVE':
            main_msg = "Negative outlook detected. Investment carries significant risk."
        else:
            main_msg = "Strong negative signal. Avoid investment at this time."
        
        # Add risk reasoning if any risks were found
        risk_detail = ""
        if primary_risk is not None:
            risk_detail = f" Primary concern: {primary_risk}."
        
        # Add sentiment context
        sentiment_dir = sentiment_data.get('sentiment', 'NEUTRAL')
        if sentiment_dir == 'POSITIVE':
            sentiment_detail = " Overall news coverage is positive."
        elif sentiment_dir == 'NEGATIVE':
            sentiment_detail = " Overall news coverage is negative."
        else:
            sentiment_detail = " News coverage is mixed or neutral."
        
        recommendation = main_msg + risk_detail + sentiment_detail
        return recommendation
    
    
    def _build_technical_recommendation(self, indicator, opportunity,
                                         risk, confidence, validated):
        """
        Build the technical recommendation using trading style indicators.
        For users who want the raw data in a standardised format.
        """
        # Map indicator to a trading action
        action_map = {
            'STRONG_POSITIVE': 'STRONG_BUY',
            'MODERATE_POSITIVE': 'MODERATE_BUY',
            'WEAK_POSITIVE': 'WEAK_BUY',
            'NEUTRAL': 'HOLD',
            'WEAK_NEGATIVE': 'WEAK_SELL',
            'MODERATE_NEGATIVE': 'MODERATE_SELL',
            'STRONG_NEGATIVE': 'STRONG_SELL'
        }
        action = action_map.get(indicator, 'HOLD')
        
        # Get risk level for the technical string
        risk_data = validated['risk']
        risk_count = risk_data.get('risk_count', 0)
        if risk_count >= 5:
            risk_level = 'HIGH'
        elif risk_count >= 3:
            risk_level = 'MODERATE'
        else:
            risk_level = 'LOW'
        
        # Build the technical string
        technical = (f"{action} | RISK: {risk_level} | "
                     f"CONFIDENCE: {round(confidence)}% | "
                     f"OPP: {round(opportunity, 1)} | "
                     f"RSK: {round(risk, 1)}")
        
        return technical


