class SentimentScorer(BaseAnalyser):#Calculates sentiment score from keyword matches.
    """    
    1. Error check
    2. Go through mathces + add weighted score
    3. Incldue modifies
    4. Classify overall sentiment 
    """
    def __init__(self, article_category=None, category_metadata=None):
        super().__init__(article_category)
        self.sentiment_weights = {}#Get cat sentiment multi
        for cat_name, cat_data in category_metadata.items():
            if 'sentiment_score' in cat_data:
                self.sentiment_weights[cat_name] = cat_data['sentiment_score']
        self.modifier_effects = {}#get multis
        for cat_name, cat_data in category_metadata.items():
            if 'multiplier' in cat_data:
                self.modifier_effects[cat_name] = cat_data['multiplier']
    
    def analyse(self, matches):#use matched wrod from aho to get sentiment 
        """
Return dict with following:
    Overall score
    sentiment
    pos score
    neg score
    keywords that give that sentiment
        """

     
        positive_score = 0.0
        negative_score = 0.0
        keyword_details = []
        
        for match in matches:
            category = match['category']
            if category not in self.sentiment_weights:
                continue
            base_weight = self.sentiment_weights[category]
            modifier = self._check_for_modifier(match, matches)# Multi check
            final_weight = base_weight * modifier
            if final_weight > 0:#Total work out
                positive_score += final_weight
            else:
                negative_score += abs(final_weight)
            keyword_details.append({
                'keyword': match['keyword'],
                'base_weight': base_weight,
                'modifier': modifier if modifier != 1.0 else None,
                'final_weight': final_weight,
                'context': match['context']
            })
        
        overall = positive_score - negative_score
        
        if overall > 5:#gedt user friendly sentiment based on score
            sentiment = 'POSITIVE'
        elif overall < -5:
            sentiment = 'NEGATIVE'
        else:
            sentiment = 'NEUTRAL'


        
        return {
            'overall_score': round(overall, 2),
            'sentiment': sentiment,
            'positive_score': round(positive_score, 2),
            'negative_score': round(negative_score, 2),
            'breakdown': keyword_details
        }
    
    def _check_for_modifier(self, current_match, all_matches):#use the 20 character away rule
  
        current_position = current_match['position']
        for match in all_matches:# Check each match
            category = match['category']
            if category not in self.modifier_effects:
                continue
            modifier_position = match['position']
            if modifier_position >= current_position:# multi before word
                continue
            distance = current_position - modifier_position
            if distance <= 20:#20 char check
                return self.modifier_effects[category]
        # No found
        return 1.0
    
    
    def _generate_neutral_output(self):#error protection
        return {
            'overall_score': 0.0,
            'sentiment': 'NEUTRAL',
            'positive_score': 0.0,
            'negative_score': 0.0,
            'breakdown': []
        }

class RiskTagger(BaseAnalyser):#Find specific risk events from keywords
    """
    Algo logic
    1. Error cehck
    2. Identify and group matches risk cat
    3. calc severity based on frequency
    4. calc  risk score
    5. Apply category multis
    """
    
    def __init__(self, article_category=None, category_metadata=None):
        super().__init__(article_category)
        
        # Extract risk scores
        self.risk_scores = {}
        for cat_name, cat_data in category_metadata.items():
            if 'risk_score' in cat_data:
                self.risk_scores[cat_name] = cat_data['risk_score']
        
        self.risk_categories = {
            'risk_financial': 'Financial Risk',
            'risk_legal': 'Legal Risk',
            'risk_quality': 'Quality/Operations Risk',
            'risk_market': 'Market Risk'
        }
        
        # Severity thresholds based on keyword count
        self.severity_thresholds = {
            'HIGH': 5,      
            'MODERATE': 3,  
            'LOW': 1        
        }
        
    
    
    def analyse(self, matches):
        """
        analyse risk from keyword matches.
        
        Will output dict like below
            dict: {
                'detected_risks': dict of risk categories ,
                'overall_risk_score':  (0-100),
                'primary_risk': str (highest severity risk),
                'risk_count': int (total risk keywords found)
            }
        """
        
        # Error handle
        if not matches:
            return self._generate_zero_risk_output()
        

        detected_risks = {}
        
        # Scan throug heach matcg
        for match in matches:
            category = match['category']
            
            # Exlude non risk catergories
            if category not in self.risk_categories:
                continue
            risk_name = self.risk_categories[category]
            
            # Initialize this risk category if first time seeing it
            if risk_name not in detected_risks:
                detected_risks[risk_name] = {
                    'count': 0,
                    'keywords': [],
                    'evidence': [],
                    'category': category
                }
            detected_risks[risk_name]['count'] += 1
            detected_risks[risk_name]['keywords'].append(match['keyword'])
            detected_risks[risk_name]['evidence'].append(match['context'])
        
        # Error if no risk found
        if not detected_risks:
            return self._generate_zero_risk_output()
        
        for risk_name, risk_data in detected_risks.items():#Severity worked out
            count = risk_data['count']
            
            # Determine severity based on frequency
            if count >= self.severity_thresholds['HIGH']:
                severity = 'HIGH'
            elif count >= self.severity_thresholds['MODERATE']:
                severity = 'MODERATE'
            else:
                severity = 'LOW'
            
            risk_data['severity'] = severity
            risk_data['evidence'] = risk_data['evidence'][:3]
        
        # Calculate overall risk score bY APPLYING CATEGORY MULTIPLIER
        overall_score = self._calculate_overall_risk(detected_risks)
        multiplier = self.get_category_multiplier()
        overall_score = overall_score * multiplier
        

        primary_risk = self._find_primary_risk(detected_risks)        # Find primary risk (highest severity)
        total_count = sum(data['count'] for data in detected_risks.values())        # Count total risk keywords
 
        return {
            'detected_risks': detected_risks,
            'overall_risk_score': round(overall_score, 2),
            'primary_risk': primary_risk,
            'risk_count': total_count,
            'category_multiplier': multiplier
        }
    
    
    def _calculate_overall_risk(self, detected_risks):
        """
        Calculate overall risk score from detected risks.
        Via severity and risk tagging
        """
 

        # Severity weights
        severity_weights = {
            'HIGH': 10,
            'MODERATE': 5,
            'LOW': 2
        }
        
        total_score = 0
        
        # Calculate weighted score for each risk
        for risk_name, risk_data in detected_risks.items():
            severity = risk_data['severity']
            count = risk_data['count']
            weight = severity_weights[severity]
            risk_score = weight * count
            total_score += risk_score
        
        # Create a standard for the score
        normalized_score = min(total_score * 2, 100) 
        return normalized_score
    
    
    def _find_primary_risk(self, detected_risks):
        """
        Find the primary (most severe) risk category to feedback to user
        """
        # Severity order for comparison
        severity_order = {'HIGH': 3, 'MODERATE': 2, 'LOW': 1}
        primary_risk = None
        highest_severity_value = 0
        highest_count = 0
        for risk_name, risk_data in detected_risks.items():
            severity = risk_data['severity']
            count = risk_data['count']
            severity_value = severity_order[severity]
            
            #Compare with current primary
            if severity_value > highest_severity_value:
                primary_risk = risk_name
                highest_severity_value = severity_value
                highest_count = count
            elif severity_value == highest_severity_value and count > highest_count:
                primary_risk = risk_name
                highest_count = count
        
        return primary_risk
    
    
    def _generate_zero_risk_output(self):
        return {
            'detected_risks': {},
            'overall_risk_score': 0.0,
            'primary_risk': None,
            'risk_count': 0,
            'category_multiplier': self.get_category_multiplier()
        }


