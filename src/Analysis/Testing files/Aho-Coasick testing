if __name__ == "__main__":
    print("=" * 60)
    print("AHO-CORASICK ALGORITHM TEST")
    print("=" * 60)
    
    # Test dictionary
    test_keywords = {
        'lawsuit': 'risk_legal',
        'safety concerns': 'risk_quality',
        'growth': 'sentiment_positive_strong',
        'he': 'test_pronoun',
        'she': 'test_pronoun',
        'record profits': 'sentiment_positive_strong',
        'significant': 'modifier_intensifier',
        'losses': 'sentiment_negative_moderate'
    }
    
    # Build the automaton
    ac = AhoCorasick(test_keywords)
    ac.build_trie()
    ac.build_failure_links()
    ac.build_output_links()
    
    print("\n✅ Algorithm initialized successfully!\n")
    
    # TEST 1: Simple single word match
    print("TEST 1: Single word match")
    print("-" * 60)
    text1 = "Company faces lawsuit over patent issues"
    results1 = ac.search(text1)
    print(f"Text: '{text1}'")
    print(f"Matches found: {len(results1)}")
    for match in results1:
        print(f"  - '{match['keyword']}' ({match['category']}) at position {match['position']}")
        print(f"    Context: {match['context']}")
    
    # TEST 2: Multi-word phrase match
    print("\n\nTEST 2: Multi-word phrase match")
    print("-" * 60)
    text2 = "Product recall due to safety concerns over battery defects"
    results2 = ac.search(text2)
    print(f"Text: '{text2}'")
    print(f"Matches found: {len(results2)}")
    for match in results2:
        print(f"  - '{match['keyword']}' ({match['category']}) at position {match['position']}")
        print(f"    Context: {match['context']}")
    
    # TEST 3: Overlapping matches (she contains he)
    print("\n\nTEST 3: Overlapping matches")
    print("-" * 60)
    text3 = "She said he would be there"
    results3 = ac.search(text3)
    print(f"Text: '{text3}'")
    print(f"Matches found: {len(results3)}")
    for match in results3:
        print(f"  - '{match['keyword']}' ({match['category']}) at position {match['position']}")
        print(f"    Context: {match['context']}")
    
    # TEST 4: Multiple categories in one sentence
    print("\n\nTEST 4: Multiple categories")
    print("-" * 60)
    text4 = "Despite record profits, company faces lawsuit and safety concerns"
    results4 = ac.search(text4)
    print(f"Text: '{text4}'")
    print(f"Matches found: {len(results4)}")
    for match in results4:
        print(f"  - '{match['keyword']}' ({match['category']}) at position {match['position']}")
        print(f"    Context: {match['context']}")
    
    # TEST 5: Modifier proximity detection
    print("\n\nTEST 5: Modifier proximity (for your modifier logic)")
    print("-" * 60)
    text5 = "Company reports significant losses in Q3"
    results5 = ac.search(text5)
    print(f"Text: '{text5}'")
    print(f"Matches found: {len(results5)}")
    
    # Sort results by position to check proximity
    results5_sorted = sorted(results5, key=lambda x: x['position'])
    for match in results5_sorted:
        print(f"  - '{match['keyword']}' ({match['category']}) at position {match['position']}")
        print(f"    Context: {match['context']}")
    
    # Check if modifier is close to another keyword
    print("\n  Proximity check:")
    for i in range(len(results5_sorted) - 1):
        current = results5_sorted[i]
        next_match = results5_sorted[i + 1]
        distance = next_match['position'] - current['end_position']
        print(f"  Distance between '{current['keyword']}' and '{next_match['keyword']}': {distance} chars")
        if distance <= 20 and 'modifier' in current['category']:
            print(f"    → Modifier '{current['keyword']}' should apply to '{next_match['keyword']}'!")
    
    print("\n" + "=" * 60)
    print("ALL TESTS COMPLETE!")
    print("=" * 60)
