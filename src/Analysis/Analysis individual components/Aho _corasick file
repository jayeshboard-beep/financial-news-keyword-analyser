    def print_trie(node, prefix="", indent=0):
        """Helper function to visualize the Trie"""
        if node.is_end_of_word:
            print("  " * indent + f"'{prefix}' [END] - Keywords: {node.keywords}")
        for char, child in node.children.items():
            print("  " * indent + f"'{char}' →")
            print_trie(child, prefix + char, indent + 1)
    
    print("Trie Structure:")
    print_trie(ac.root)
