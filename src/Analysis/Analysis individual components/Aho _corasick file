class TrieNode:

    #Represents a single node in the Trie structure for Aho-Corasick algorithm.
  


    self.children = {}
    self.is_end_of_word = False
    
    # List of keywords that end at this node
    self.keywords = []
    
    # Failure link - where to jump if next character doesn't match
    self.fail_link = None
    
    # Output link - shortcut to find overlapping matches
    self.output_link = None



class AhoCorasick:

    #Aho-Corasick algorithm implementation for multi-pattern string matching.
 
    
    def __init__(self, keyword_dict):
        #Inputs:
            #keyword_dict: Dictionary mapping keywords to categories


        # Trie root note created+failure links
        self.root = TrieNode()
        self.root.fail_link = self.root
        
        # Store the keyword dictionary for later lookup
        self.keyword_dict = keyword_dict
        
    def insert_keyword(self, keyword):
       #Keyword to be created into a trie is produced

        current_node = self.root

        # Process each character in the keyword
        for char in keyword:
            if char not in current_node.children:
                current_node.children[char] = TrieNode()
            
            # Move to the child node for this Letter
            current_node = current_node.children[char]
        
        # End of all characters in a word
        current_node.is_end_of_word = True
        current_node.keywords.append(keyword)
    
    def build_trie(self):
      #Buid the trie strucutre

        for keyword in self.keyword_dict.keys():
            normalized_keyword = keyword.lower()
            self.insert_keyword(normalized_keyword)


