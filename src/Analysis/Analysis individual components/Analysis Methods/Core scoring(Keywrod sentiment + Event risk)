import logging


class BaseAnalyzer:
    def __init__(self, article_category=None):
        self.article_category = article_category
        self.category_multipliers = {
            'Legal': 1.5,
            'Business': 1.2,
            'Finance': 1.3,
            'Technology': 1.0,
            'General': 1.0
        }
    def get_category_multiplier(self):
        return self.category_multipliers.get(self.article_category, 1.0)
    
    def analyze(self, matches):
        raise NotImplementedError("Subclasses must implement analyze()")




class SentimentScorer(BaseAnalyzer):
    
    def __init__(self, article_category=None, category_metadata=None):
        super().__init__(article_category)
        
        # Extract sentiment weights from CATEGORY_METADATA
        self.sentiment_weights = {}
        for cat_name, cat_data in category_metadata.items():
            if 'sentiment_score' in cat_data:
                self.sentiment_weights[cat_name] = cat_data['sentiment_score']
        
        # Extract modifier multipliers from CATEGORY_METADATA
        self.modifier_effects = {}
        for cat_name, cat_data in category_metadata.items():
            if 'multiplier' in cat_data:
                self.modifier_effects[cat_name] = cat_data['multiplier']
        
        # Modifier detection range (characters before keyword)
        self.modifier_range = 20  # ~3-4 wordsx
        
        logging.info(f"SentimentScorer initialized with {len(self.sentiment_weights)} sentiment categories")
    
    def analyze(self, matches):
        """
        Main analysis method.
        
        Args:
            matches: List of dicts from Aho-Corasick with keys:
                - 'keyword': str
                - 'category': str
                - 'position': int (character index)
                - 'context': str
        
        Returns:
            dict: {
                'overall_score': float,
                'sentiment': str ('POSITIVE', 'NEGATIVE', 'NEUTRAL'),
                'confidence': str ('HIGH', 'MODERATE', 'LOW'),
                'positive_score': float,
                'negative_score': float,
                'breakdown': list of keyword details
            }
        """
        
        # Handle edge case: no matches
        if not matches:
            logging.info("No matches found - returning neutral sentiment")
            return self._generate_neutral_output()
        
        # Step 1: Build modifier position map
        modifier_map = self._build_modifier_map(matches)
        logging.info(f"Found {len(modifier_map)} modifiers in text")
        
        # Step 2: Calculate scores for sentiment keywords
        scores = self._calculate_keyword_scores(matches, modifier_map)
        
        # Step 3: Generate final output with classification
        output = self._generate_output(scores)
        
        logging.info(f"Sentiment analysis complete: {output['sentiment']} (score: {output['overall_score']})")
        return output
