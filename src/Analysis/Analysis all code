class HeadlineFrequencyTracker(BaseAnalyzer):
    """
    Tracks how often a product is mentioned across article headlines.
    High frequency = market attention = potential volatility.
    """
    
    def analyze(self, headlines, product_name):
        """
        Analyze headline frequency for a product.

        Output:Dictionary with frequency analysis results
        """
        if not headlines:
            #Error handling
            return None
            
        # Count how many headlines mention the product
        mention_count = 0
        total_headlines = len(headlines)
        
        # search for the product name 
        for headline in headlines:
            if product_name.lower() in headline.lower():
                mention_count += 1
        
        # Calculate percentage
        if total_headlines > 0:
            percentage = (mention_count / total_headlines) * 100
        else:
            percentage = 0
        
        # Determine attention level based on percentage
        attention_level = self._get_attention_level(percentage)
        
        return {
            'mention_count': mention_count,
            'total_headlines': total_headlines,
            'percentage': round(percentage, 1),
            'attention_level': attention_level
        }
    
    def _get_attention_level(self, percentage):
        #Converts percentage to something user will understnadly easily


        if percentage >= 60:
            return 'HIGH'
        elif percentage >= 30:
            return 'MODERATE'
        else:
            return 'LOW'
        







class ContradictionDetector(BaseAnalyzer):
    """
    Detects contradictory sentiment signals across headlines.
    Contradictions indicate market uncertainty and increased risk.
    
    Method:
    1: Find out sentiment for each headline
    2:Count positive vs negative headlines
    3:Check for contraciction/contradicting pairs
    """
    
    def __init__(self, aho_corasick, category_metadata):
        super().__init__()
        self.aho_corasick = aho_corasick
        self.category_metadata = category_metadata 
    
    def analyze(self, headlines):

        if not headlines or len(headlines) < 2:#Error handling
            return None
        
        # Step 1
        headline_sentiments = []
        for headline in headlines:
            sentiment = self._analyze_headline_sentiment(headline)
            headline_sentiments.append({
                'text': headline,
                'sentiment': sentiment
            })
        
        # Step 2
        positive_count = 0
        negative_count = 0
        neutral_count = 0
        
        for item in headline_sentiments:
            if item['sentiment'] == 'POSITIVE':
                positive_count += 1
            elif item['sentiment'] == 'NEGATIVE':
                negative_count += 1
            else:
                neutral_count += 1
        
        # Step 3: Check for contradictions
        contradiction_detected = False
        if positive_count > 0 and negative_count > 0:
            contradiction_detected = True
        conflicting_pairs = []
        if contradiction_detected:
            conflicting_pairs = self._find_conflicting_pairs(headline_sentiments)
        
        # Calculate contradiction score (0-10 scale)
        score = self._calculate_contradiction_score(positive_count, negative_count, neutral_count)
        
        return {
            'contradiction_detected': contradiction_detected,
            'score': score,
            'positive_count': positive_count,
            'negative_count': negative_count,
            'neutral_count': neutral_count,
            'conflicting_pairs': conflicting_pairs
        }
    
    def _analyze_headline_sentiment(self, headline):
    matches = self.aho_corasick.search(headline)
    if not matches:
        return 'NEUTRAL'
    
    total_score = 0
    for match in matches:
        category = match['category']
        # Look up sentiment score directly from category metadata
        if category in self.category_metadata:
            cat_data = self.category_metadata[category]
            weight = cat_data.get('sentiment_score', 0)
            total_score = total_score + weight
    
    if total_score > 0:
        return 'POSITIVE'
    elif total_score < 0:
        return 'NEGATIVE'
    else:
        return 'NEUTRAL'
    
    def _get_keyword_weight(self, keyword):
 
        for category, data in self.category_metadata.items():
            if keyword in data.get('keywords', []):
                # Return sentiment_score if it exists, otherwise 0
                return data.get('sentiment_score', 0)
        
        return 0  
    
    def _find_conflicting_pairs(self, headline_sentiments):

        #Find pairs of headlines with opposite sentiments.

        conflicting_pairs = []
        
        # Find positive headlines
        positive_headlines = [h for h in headline_sentiments if h['sentiment'] == 'POSITIVE']
        # Find negative headlines
        negative_headlines = [h for h in headline_sentiments if h['sentiment'] == 'NEGATIVE']
        
        # Pair them up (just take first few for simplicity)
        for i in range(min(3, len(positive_headlines), len(negative_headlines))):
            pair = {
                'positive': positive_headlines[i]['text'],
                'negative': negative_headlines[i]['text']
            }
            conflicting_pairs.append(pair)
        
        return conflicting_pairs
    
    def _calculate_contradiction_score(self, positive_count, negative_count, neutral_count):
        """
        Calculate contradiction score based on sentiment distribution.
        Higher score = more disagreement = higher uncertainty.

        """
        total = positive_count + negative_count + neutral_count
        
        if total == 0:
            return 0
        
        # If all same sentiment, no contradiction
        if positive_count == total or negative_count == total or neutral_count == total:
            return 0
        
        # Calculate balance (closer to 50/50 = higher score)
        smaller = min(positive_count, negative_count)
        larger = max(positive_count, negative_count)
        
        if larger == 0:
            return 0
        
        balance_ratio = smaller / larger

        score = balance_ratio * 10
        
        return round(score)










#Volatility and trends!

class TrendVolatilityAnalyzer(BaseAnalyzer):
    """
    Analyzes market volatility by detecting sentiment fluctuations and emotional language.
    
   Parts:
    1. Calculate sentiment balance volatility (0-35)
    2. Check for contradiction signals (0-25 points)
    3. Evaluate frequency spike indicators (0-20 points)
    4. Count emotional language intensity (0-20 points)
    5. Combine scores and determine confidence level
    """
    
    def __init__(self, article_category=None, category_metadata=None):
        super().__init__(article_category)
        
        # Extract volatility scores from metadata
        self.volatility_scores = {}
        for cat_name, cat_data in category_metadata.items():
            if 'volatility_score' in cat_data:
                self.volatility_scores[cat_name] = cat_data['volatility_score']
        
        # Confidence thresholds set based on idea of volatility level
        self.confidence_thresholds = {
            'HIGH': 30,      # 0-30 = confident trend prediction
            'MODERATE': 60,  # 31-60 = moderate confidence
            'LOW': 100       # 61-100 = low confidence (unreliable)
        }
    
    
    def analyze(self, sentiment_result, frequency_result, contradiction_result, keyword_matches):
        """
       Step 5
         Analyze market volatility from combined analyzer outputs.

        Outputs:
            dict: {
                'volatility_score': float (0-100),
                'confidence_level': str ('HIGH', 'MODERATE', 'LOW'),
                'components': dict of scores,
                'interpretation': str explanation to be given to user
            }
        """
        
        # Calculate each volatility component
        balance_component = self._calculate_balance_volatility(sentiment_result)
        contradiction_component = self._calculate_contradiction_volatility(contradiction_result)
        frequency_component = self._calculate_frequency_volatility(frequency_result)
        emotion_component = self._calculate_emotion_volatility(keyword_matches)
        
        # Combinination
        total_volatility = balance_component + contradiction_component + frequency_component + emotion_component
        if total_volatility > 100:
            total_volatility = 100
        
        # Determine confidence level
        confidence = self._determine_confidence(total_volatility)
        
        # Produce interpretation
        interpretation = self._generate_interpretation(
            total_volatility, 
            balance_component, 
            contradiction_component, 
            frequency_component, 
            emotion_component
        )
        return {
            'volatility_score': round(total_volatility, 2),
            'confidence_level': confidence,
            'components': {
                'sentiment_balance': round(balance_component, 2),
                'contradictions': round(contradiction_component, 2),
                'frequency_spike': round(frequency_component, 2),
                'emotional_intensity': round(emotion_component, 2)
            },
            'interpretation': interpretation
        }
    
    
    def _calculate_balance_volatility(self, sentiment_result):#Calculate volatility from sentiment balance(Step 1)

        # Error handling 
        if sentiment_result is None:
            return 0.0
        
        # Extract scores
        positive_score = sentiment_result.get('positive_score', 0.0)
        negative_score = sentiment_result.get('negative_score', 0.0)
        
        # Calculate total sentiment 
        total_score = positive_score + negative_score
        
        # error handle for if both P and N are 0
        if total_score == 0:
            return 0.0
        
        # Calculate how far apart the scores are
        score_difference = abs(positive_score - negative_score)
        
        # Calculate balance ratio (0-1 where 0 is perfectly balanced)
        balance_ratio = score_difference / total_score
        
        # Invert to get volatility
        balance_volatility = 1.0 - balance_ratio
        
        # Scale to appropriate range
        component_score = balance_volatility * 35
        
        return component_score
    
    
    def _calculate_contradiction_volatility(self, contradiction_result):
        """
        (Step 2)
        Calculate volatility from headline contradictions.
        Conflicting headlines = market confusion = volatile.
        
        Returns: 0-25 points
        """
        
        # Error check: if there is no contradiction 
        if contradiction_result is None:
            return 0.0
        
        # Check if contradictions is there
        contradiction_detected = contradiction_result.get('contradiction_detected', False)
        
        # Chose is it volatile or not
        if contradiction_detected:
            return 25.0
        else:
            return 0.0
    
    
    def _calculate_frequency_volatility(self, frequency_result):
        """
            (Step 3)
         Calculate volatility from mention frequency.
        High frequency = sudden attention spike = potential trend shift.
        
        Returns: 0-20 points
        """
        
        # Error check; No frequency data
        if frequency_result is None:
            return 0.0

        attention_level = frequency_result.get('attention_level', 'LOW')
        
        # Evaluate based on attention level
        if attention_level == 'HIGH':
            return 20.0
        elif attention_level == 'MODERATE':
            return 10.0
        else:
            return 0.0
    def _calculate_emotion_volatility(self, keyword_matches):
        """
        (Step 4)
        Calculate volatility from emotional language intensity.
        Strong emotional keywords = market instability.
        
        Returns: 0-20 points
        """
        

        # Count emotional language keywords found
        emotion_count = 0
        
        # Loop through matches
        for match in keyword_matches:
            category = match['category']
            if 'strong' in category: # Check for strong sentiment keywords
                emotion_count += 1
            elif category == 'volatility_emotional': # Check for volatility emotional keywords
                emotion_count += 1
            elif category == 'modifier_intensifier':# Check for intensifier modifiers
                emotion_count += 1
        
        # Each emotional keyword adds 2 points 
        emotion_score = emotion_count * 2
        if emotion_score > 20:
            emotion_score = 20
        return float(emotion_score)
    
    
    def _determine_confidence(self, volatility_score):
        """
        Step 5
        Determine confidence level in trend predictions.
        Inverse relationship: high volatility = low confidence.
        """
        
        # Check against thresholds
        if volatility_score <= self.confidence_thresholds['HIGH']:
            return 'HIGH'
        elif volatility_score <= self.confidence_thresholds['MODERATE']:
            return 'MODERATE'
        else:
            return 'LOW'
    
    
    def _generate_interpretation(self, total_volatility, balance, contradiction, frequency, emotion):
        """
        Generate userr friendly interpretation of volatility.
        """
        
        # Start with initial interpretation
        if total_volatility <= 30:
            base = "Low volatility detected - market sentiment is stable and clear."
        elif total_volatility <= 60:
            base = "Moderate volatility detected - some market uncertainty present."
        else:
            base = "High volatility detected - significant market uncertainty and instability."
        
        # Add details to imp[rove accuracy]
        contributors = []
        
        if balance > 20:
            contributors.append("conflicting sentiment scores")
        
        if contradiction > 0:
            contributors.append("contradictory headlines")
        
        if frequency > 0:
            contributors.append("sudden attention spike")
        
        if emotion > 10:
            contributors.append("strong emotional language")
        
        # Build final interpretation
        if contributors:
            details = ", ".join(contributors)
            interpretation = f"{base} Primary factors: {details}."
        else:
            interpretation = base
        
        return interpretation

















#ROI CALCULATOR


class ROICalculator(BaseAnalyser):
    """
    Combines all analyser outputs to produce final ROI recommendation.
    
    Process:
    1. Calculate opportunity score (sentiment + trend + frequency)
    2. Calculate risk score (base risk + volatility + contradictions)
    3. Calculate confidence score (volatility penalties)
    4. Multiply net score with confidence multiplier
    5. Determine ROI category from net score
    6. Generate user friendly recommendation
    """
    
    def __init__(self, category_metadata=None):
        super().__init__()
        self.category_metadata = category_metadata
        
        # ROI category thresholds
        self.roi_thresholds = {
            'STRONG_POSITIVE': 30,
            'MODERATE_POSITIVE': 15,
            'WEAK_POSITIVE': 5,
            'NEUTRAL_HIGH': 5,
            'NEUTRAL_LOW': -5,
            'WEAK_NEGATIVE': -15,
            'MODERATE_NEGATIVE': -30
        }
    
    
    def calculate_roi(self, analyser_results):
        """
        Main method - calculates ROI from all analyser outputs.
        
        Inputs:
                'sentiment': SentimentScorer output,
                'risk': RiskTagger output,
                'volatility': TrendVolatilityAnalyser output,
                'frequency': HeadlineFrequencyTracker output 
                'contradictions': ContradictionDetector output 
                'trend_prediction': EventTrendsDatabase output 
    
        
        Returns:
            Complete ROI analysis with scores and recommendation as a dictionary
        """
        
        # Step 1: Validate inputs
        validation = self._validate_inputs(analyser_results)
        if not validation['valid']:
            return self._generate_error_output(validation['missing'])
        
        # Step 2: Extract analyser results
        sentiment_result = analyser_results['sentiment']
        risk_result = analyser_results['risk']
        volatility_result = analyser_results['volatility']
        frequency_result = analyser_results.get('frequency')
        contradiction_result = analyser_results.get('contradictions')
        trend_prediction = analyser_results.get('trend_prediction')
        
        # Step 3: Calculate Indivudal scores
        opportunity_score = self._calculate_opportunity_score(
            sentiment_result, 
            trend_prediction, 
            frequency_result
        )
        
        risk_score = self._calculate_risk_score(
            risk_result, 
            volatility_result, 
            contradiction_result
        )
        
        confidence_score = self._calculate_confidence_score(
            volatility_result, 
            trend_prediction, 
            contradiction_result
        )
        
        # Step 4: Calculate total score using confidence multiplier
        net_score = self._calculate_net_score(
            opportunity_score, 
            risk_score, 
            confidence_score
        )
        
        # Step 5: Determine ROI category
        roi_category = self._determine_roi_category(net_score)
        
        # Step 6: Generate recommendations
        user_recommendation = self._generate_user_recommendation(
            roi_category, 
            opportunity_score, 
            risk_score, 
            confidence_score,
            risk_result,
            volatility_result
        )
        
        technical_indicator = self._generate_technical_indicator(
            roi_category,
            risk_score,
            confidence_score
        )
        
        # Step 7: Build output dictionary
        return self._build_output(
            roi_category,
            user_recommendation,
            technical_indicator,
            opportunity_score,
            risk_score,
            confidence_score,
            net_score,
            sentiment_result,
            risk_result,
            volatility_result,
            trend_prediction,
            analyser_results  # Solution to problem 14: Now passing analyser_results
        )
    
    
    def _validate_inputs(self, analyser_results):
        """
        Check that the essential analysers data was valid
        
        Returns:
            dict: {'valid': bool, 'missing': list}
        """
        required = ['sentiment', 'risk', 'volatility']
        missing = []
        
        for key in required:# Loop through to check
            if key not in analyser_results:
                missing.append(key)
            elif analyser_results[key] is None:
                missing.append(key)
        
        if missing:
            return {'valid': False, 'missing': missing}
        return {'valid': True, 'missing': []}
    
    
    def _calculate_opportunity_score(self, sentiment_result, trend_prediction, frequency_result): # Step 1
        """
        Calculate opportunity score 
        
        Build from:
            Base: sentiment score (normalised to 0-100)
            Bonus: +20 if upward trend predicted
            Bonus: +10 if high frequency AND positive sentiment
        """
        
        # Get sentiment score (-100 to +100 range)
        sentiment_score = sentiment_result.get('overall_score', 0.0)
        sentiment_type = sentiment_result.get('sentiment', 'NEUTRAL')
        
        # Normalise sentiment to 0-100 scale
        if sentiment_score > 0:
            base_opportunity = (sentiment_score / 100) * 100  # Scale positive sentiment
        else:
            base_opportunity = 0.0
        
        # Add trend prediction 
        if trend_prediction is not None:
            prediction = trend_prediction.get('prediction', 'NEUTRAL')
            if prediction == 'UPWARD':
                base_opportunity += 20
        
        # Add frequency 
        if frequency_result is not None:
            attention_level = frequency_result.get('attention_level', 'LOW')
            
            # Only add frequency bonus if sentiment is positive
            if attention_level == 'HIGH' and sentiment_type == 'POSITIVE':
                base_opportunity += 10
        

        opportunity = min(100, base_opportunity)
        
        return round(opportunity, 2)# returns opportunity at 2 dp as required
    
    
    def _calculate_risk_score(self, risk_result, volatility_result, contradiction_result): # Step 2
        """
        Calculate risk score (0-100).
        
        Components:
        - Base: risk tagger score
        - Change if the following:
            +15 if high volatility (>60)
            +10 if contradictions detected
        """
        

        base_risk = risk_result.get('overall_risk_score', 0.0)
        volatility_score = volatility_result.get('volatility_score', 0.0)
        
        # Adjust for high volatility
        volatility_adjustment = 0
        if volatility_score > 60:
            volatility_adjustment = 15
        
        # Adjust for contradictions
        contradiction_adjustment = 0
        if contradiction_result is not None:
            contradiction_detected = contradiction_result.get('contradiction_detected', False)
            if contradiction_detected:
                contradiction_adjustment = 10
        
        # Calc total using risk cscores
        total_risk = base_risk + volatility_adjustment + contradiction_adjustment
        

        risk = min(100, total_risk)
        
        return round(risk, 2)
    
    
    def _calculate_confidence_score(self, volatility_result, trend_prediction, contradiction_result): # Step 3
        """
        Calculate confidence score (0-100).
        
        Work by using negatives(start at 100 then reduce based on the following:)
        - Volatility penalty (biggest factor)
        - Sample size penalty (-20 if <5 historical events)
        - Contradiction penalty (-15 if detected)
        """
        
        # Start with max confidence
        base_confidence = 100
        
        # Volatility is the biggest effect
        volatility_score = volatility_result.get('volatility_score', 0.0)
        volatility_penalty = volatility_score
        
        # Sample size penalty
        sample_size_penalty = 0
        if trend_prediction is not None:
            sample_size = trend_prediction.get('sample_size', 0)
            if sample_size < 5:
                sample_size_penalty = 20
        
        # Contradiction penalty
        contradiction_penalty = 0
        if contradiction_result is not None:
            contradiction_detected = contradiction_result.get('contradiction_detected', False)
            if contradiction_detected:
                contradiction_penalty = 15
        
        # Calculate final confidence
        confidence = base_confidence - volatility_penalty - sample_size_penalty - contradiction_penalty
        confidence = max(0, confidence)
        
        return round(confidence, 2)
    
    
    def _calculate_net_score(self, opportunity, risk, confidence):#Step 4
        """
        Calculate final net score using confidence multiplier.
        
        Formula: (opportunity - risk) * (confidence / 100)
            -Adapted from risk-adjusted return principles


        This formula ensures low confidence dramatically reduces the net score thus preventing overconfident predictions in uncertain markets.
        """
        
        raw_score = opportunity - risk
        confidence_multiplier = confidence / 100
        net_score = raw_score * confidence_multiplier
        
        return round(net_score, 2)
    
    
    def _determine_roi_category(self, net_score):#Step 5
        """
        Map net score to ROI category using bounds.
        
        7-level system provides realtively detailed insight whilst aalso being simple for users.
        """
        
        if net_score >= self.roi_thresholds['STRONG_POSITIVE']:
            return 'STRONG_POSITIVE'
        elif net_score >= self.roi_thresholds['MODERATE_POSITIVE']:
            return 'MODERATE_POSITIVE'
        elif net_score >= self.roi_thresholds['WEAK_POSITIVE']:
            return 'WEAK_POSITIVE'
        elif net_score >= self.roi_thresholds['NEUTRAL_LOW']:
            return 'NEUTRAL'
        elif net_score >= self.roi_thresholds['WEAK_NEGATIVE']:
            return 'WEAK_NEGATIVE'
        elif net_score >= self.roi_thresholds['MODERATE_NEGATIVE']:
            return 'MODERATE_NEGATIVE'
        else:
            return 'STRONG_NEGATIVE'
    
    
    def _generate_user_recommendation(self, roi_category, opportunity, risk, confidence, risk_result, volatility_result):
        """
        Generate user-friendly recommendation text.
        
        1:Uses templates based on ROI category
        2:then adds specific details about risks and market conditions.
        """
        
        # Base recommendation templates
        base_templates = {
            'STRONG_POSITIVE': 'Strong profit potential detected with manageable risk.',
            'MODERATE_POSITIVE': 'Profit potential exists with notable considerations.',
            'WEAK_POSITIVE': 'Slight profit potential detected but proceed with caution.',
            'NEUTRAL': 'Mixed signals detected - no clear investment direction.',
            'WEAK_NEGATIVE': 'Investment not recommended due to identified concerns.',
            'MODERATE_NEGATIVE': 'Significant risk detected - avoid investment.',
            'STRONG_NEGATIVE': 'Severe risk detected - strongly avoid investment.'
        }
        
        recommendation = base_templates[roi_category]
        
   
        primary_risk = risk_result.get('primary_risk')
        if primary_risk and risk > 50:   # Add specific risk mention if detected
            recommendation += f' {primary_risk} detected - monitor developments closely.'
        volatility_level = volatility_result.get('confidence_level', 'MODERATE') # Add volatility warning if high
        if volatility_level == 'LOW':  # Low confidence = high volatility
            recommendation += ' High market volatility suggests short-term positioning only.'
        if 'POSITIVE' in roi_category and confidence < 50: # Add confidence qualifier for positive recommendations
            recommendation += ' However, low market confidence warrants additional research before committing.'
        
        return recommendation
    
    
    def _generate_technical_indicator(self, roi_category, risk_score, confidence_score):
        """
        Generate technical trading indicator format.
        
        Example: "MODERATE_BUY | RISK: HIGH | CONFIDENCE: 55%"
        """
        
        # Map ROI category to trading action
        trading_actions = {
            'STRONG_POSITIVE': 'STRONG_BUY',
            'MODERATE_POSITIVE': 'MODERATE_BUY',
            'WEAK_POSITIVE': 'WEAK_BUY',
            'NEUTRAL': 'HOLD',
            'WEAK_NEGATIVE': 'WEAK_SELL',
            'MODERATE_NEGATIVE': 'MODERATE_SELL',
            'STRONG_NEGATIVE': 'STRONG_SELL'
        }
        
        action = trading_actions[roi_category]
        
        # Determine risk level
        if risk_score >= 70:
            risk_level = 'CRITICAL'
        elif risk_score >= 50:
            risk_level = 'HIGH'
        elif risk_score >= 30:
            risk_level = 'MODERATE'
        else:
            risk_level = 'LOW'
        
        # Format technical indicator for easy to read for user
        technical = f"{action} | RISK: {risk_level} | CONFIDENCE: {confidence_score}%"
        
        return technical
    
    
    def _build_output(self, roi_category, user_recommendation, technical_indicator,
                     opportunity, risk, confidence, net_score,
                     sentiment_result, risk_result, volatility_result, trend_prediction,
                     analyser_results):  #  Added analyser_results parameter to fix problem 13
        """
        Assemble complete output dictionary with all analysis details.
        
        Structure designed for both immediate use + documentation.
        """
        
        output = {
            # Top-level summary 
            'roi_indicator': roi_category,
            'recommendation': user_recommendation,
            'technical_indicator': technical_indicator,
            
            # Score breakdown
            'scores': {
                'opportunity': opportunity,
                'risk': risk,
                'confidence': confidence,
                'net_score': net_score
            },
            
            # Explanation details
            'opportunity_breakdown': {
                'sentiment_contribution': sentiment_result.get('overall_score', 0.0),
                'trend_contribution': 20 if (trend_prediction and trend_prediction.get('prediction') == 'UPWARD') else 0,
                'frequency_contribution': 10 if self._frequency_added_opportunity(sentiment_result, analyser_results.get('frequency')) else 0
            },
            
            'risk_breakdown': {
                'base_risk': risk_result.get('overall_risk_score', 0.0),
                'volatility_adjustment': 15 if volatility_result.get('volatility_score', 0) > 60 else 0,
                'contradiction_adjustment': 10 if (analyser_results.get('contradictions') and analyser_results.get('contradictions').get('contradiction_detected')) else 0
            },
            
            'confidence_breakdown': {
                'volatility_penalty': volatility_result.get('volatility_score', 0.0),
                'sample_size_penalty': 20 if (trend_prediction and trend_prediction.get('sample_size', 0) < 5) else 0,
                'contradiction_penalty': 15 if (analyser_results.get('contradictions') and analyser_results.get('contradictions').get('contradiction_detected')) else 0
            },
            
            # Key insights that the user can read
            'key_factors': {
                'primary_risk': risk_result.get('primary_risk'),
                'trend_direction': trend_prediction.get('prediction') if trend_prediction else 'UNKNOWN',
                'volatility_level': volatility_result.get('confidence_level', 'UNKNOWN'),
                'sentiment': sentiment_result.get('sentiment', 'UNKNOWN')
            },
            
            # Metadata
            'timestamp': datetime.now().isoformat(),
            'confidence_level': self._map_confidence_to_level(confidence)
        }
        
        return output
    
    
    def _frequency_added_opportunity(self, sentiment_result, frequency_result):
        """
        Helper class for determinening if frequency contributes to opportunity.
        """
        if frequency_result is None:
            return False
        
        attention = frequency_result.get('attention_level', 'LOW')
        sentiment = sentiment_result.get('sentiment', 'NEUTRAL')
        
        return attention == 'HIGH' and sentiment == 'POSITIVE'
    
    
    def _map_confidence_to_level(self, confidence_score):
        """
        Convert numeric confidence to level (eg HIGH)
        """
        if confidence_score >= 70:
            return 'HIGH'
        elif confidence_score >= 40:
            return 'MODERATE'
        else:
            return 'LOW'
    
    
    def _generate_error_output(self, missing_data):
        """
        Return error output when data is missing.
        """
        missing_str = ', '.join(missing_data)
        
        return {
            'roi_indicator': 'INSUFFICIENT_DATA',
            'recommendation': f'Cannot calculate ROI: missing critical data ({missing_str}). Please ensure all required analysers completed successfully.',
            'technical_indicator': 'ERROR',
            'scores': None,
            'error': {
                'type': 'MISSING_DATA',
                'missing_analysers': missing_data
            },
            'timestamp': datetime.now().isoformat()
        }

















